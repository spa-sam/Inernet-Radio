{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Internet Radio",
  "version": "1.0.14",
  "identifier": "com.internetradio.player",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Internet Radio",
        "width": 500,
        "height": 760,
        "resizable": true,
        "center": true,
        "minWidth": 420,
        "minHeight": 560,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https: http:; media-src 'self' https: http: blob:; img-src 'self' https: http: data:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/spa-sam/Inernet-Radio/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk5NDg3MEU3NzI4M0NFOEUKUldTT3pvTnk1M0JJbWErdjlIZlo5aENOU0lIRFU1R1lmVFB4NmtwWkNwNzBzNHdwZ0RwSGx2TTMK"
    }
  }
}
